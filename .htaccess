<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si el recurso solicitado existe (archivo/directorio), se sirve tal cual.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Enruta todo lo demás hacia el front controller.
    RewriteRule ^ index.php [L,QSA]
</IfModule>
